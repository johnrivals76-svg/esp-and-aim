local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local GuiService = game:GetService("GuiService")

local LocalPlayer = Players.LocalPlayer
local Camera = Workspace.CurrentCamera
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

-- CONFIG
local LOCK_ON_PART = "Head"
local LERP_SPEED = 0.2
-- FOV Settings (RED)
local FOV_RADIUS = 100
local FOV_COLOR = Color3.new(1, 0, 0)
local FOV_THICKNESS = 2
-- RAINBOW ESP Settings
local ESP_TRANSPARENCY = 0.3
local RAINBOW_SPEED = 2

-- State Variables
local isLocked = false
local targetPlayer = nil
local menuOpen = false
local currentHighlight = nil
local hue = 0

-- UI Elements
local ScreenGui
local MainWindow -- The main menu window
local ToggleButton -- The button to turn aim on/off
local FOVCircle
local MinimizeButton -- To hide/show the menu

